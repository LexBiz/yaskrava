generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStatus {
  NEW
  IN_REVIEW
  NEED_INFO
  CONTACTED
  APPROVED
  REJECTED
}

enum FinancingStatus {
  NEW
  QUALIFYING
  DOCUMENTS_PENDING
  SUBMITTED
  APPROVED
  REJECTED
  FUNDED
}

enum PartnerLeadStatus {
  NEW
  IN_REVIEW
  CONTACTED
  APPROVED
  REJECTED
}

enum ApplicationTopic {
  LEASING
  FUEL
  VEHICLE
  CAREER
  OTHER
}

enum DealerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CzechRegion {
  Praha
  STREDOCESKY
  JIHOCESKY
  PLZENSKY
  KARLOVARSKY
  USTECKY
  LIBERECKY
  KRALOVEHRADECKY
  PARDUBICKY
  VYSOCINA
  JIHOMORAVSKY
  OLOMOUCKY
  ZLINSKY
  MORAVSKOSLEZSKY
}

enum DomainStatus {
  ACTIVE
  DISABLED
}

enum PlatformRole {
  SUPER_ADMIN
  YASKRAVA_MANAGER
}

enum DealerMembershipRole {
  DEALER_OWNER
  DEALER_MANAGER
  DEALER_SALES
}

enum AuditActorType {
  SYSTEM
  USER
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  DEALER_PROVISIONED
  DEALER_DEACTIVATED
  DEALER_REACTIVATED
  DEALER_DELETED
  DEALER_PASSWORD_RESET
  APPLICATION_CREATED
  APPLICATION_STATUS_UPDATED
  FINANCING_STATUS_UPDATED
  APPLICATION_ARCHIVED
  APPLICATION_NOTE_UPDATED
  APPLICATION_SOFT_DELETED
  PARTNER_LEAD_CREATED
  PARTNER_LEAD_STATUS_UPDATED
  PARTNER_LEAD_ARCHIVED
  PARTNER_LEAD_NOTE_UPDATED
  VEHICLE_CREATED
  VEHICLE_UPDATED
  VEHICLE_ARCHIVED
  VACANCY_CREATED
  VACANCY_UPDATED
  VACANCY_ARCHIVED
}

model Dealer {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  slug             String      @unique
  name             String
  legalName        String?
  status           DealerStatus @default(ACTIVE)
  defaultLocale    String      @default("en")
  accentColor      String      @default("#08D96E")
  brandPrimary     String      @default("YASK")
  brandSecondary   String      @default("RAVA")
  supportEmail     String?
  supportPhone     String?
  city             String?
  country          String?     @default("CZ")
  region           CzechRegion?
  homeDelivery     Boolean     @default(false)
  websiteTitle     String?
  footerDisclaimer String?
  appStoreUrl      String?
  playStoreUrl     String?

  deletedAt        DateTime?

  domains          DealerDomain[]
  memberships      DealerMembership[]
  applications     Application[]
  convertedPartnerLeads PartnerLead[] @relation("ConvertedDealerPartnerLeads")
  vehicles         Vehicle[]
  vacancies        Vacancy[]
  dailyMetrics     DealerDailyMetric[]
  auditLogs        AuditLog[]
}

model DealerDomain {
  id         String       @id @default(cuid())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  hostname   String       @unique
  isPrimary  Boolean      @default(false)
  status     DomainStatus @default(ACTIVE)

  dealerId   String
  dealer     Dealer       @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId])
}

model AdminUser {
  id                          String               @id @default(cuid())
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  email                       String               @unique
  passwordHash                String
  firstName                   String?
  lastName                    String?
  isActive                    Boolean              @default(true)
  platformRole                PlatformRole?

  memberships                 DealerMembership[]
  sessions                    UserSession[]
  assignedDealerApplications  Application[]        @relation("DealerAssignedApplications")
  assignedYaskravaApplications Application[]       @relation("YaskravaAssignedApplications")
  assignedFinancingCases      FinancingCase[]      @relation("YaskravaAssignedFinancingCases")
  auditLogs                   AuditLog[]           @relation("UserAuditLogs")
}

model DealerMembership {
  id         String               @id @default(cuid())
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  role       DealerMembershipRole
  isActive   Boolean              @default(true)

  userId     String
  dealerId   String
  user       AdminUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealer     Dealer               @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([userId, dealerId])
  @@index([dealerId])
}

model UserSession {
  id         String     @id @default(cuid())
  createdAt  DateTime   @default(now())
  expiresAt  DateTime
  tokenHash  String     @unique

  userId     String
  user       AdminUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Application {
  id         String            @id @default(cuid())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  submittedAt DateTime         @default(now())
  contactedAt DateTime?
  decisionAt  DateTime?
  deletedAt   DateTime?

  locale     String
  sourceDomain String
  sourcePath String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?

  fullName   String
  phone      String?
  email      String?
  city       String?
  message    String?

  consent    Boolean
  calculator Json?

  topic      ApplicationTopic  @default(LEASING)
  status     ApplicationStatus @default(NEW)
  financingStatus FinancingStatus @default(NEW)
  archived   Boolean           @default(false)
  adminNote  String?
  dealerNote String?

  dealerId   String
  vehicleId  String?
  assignedDealerUserId   String?
  assignedYaskravaUserId String?

  dealer     Dealer      @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  assignedDealerUser   AdminUser? @relation("DealerAssignedApplications", fields: [assignedDealerUserId], references: [id], onDelete: SetNull)
  assignedYaskravaUser AdminUser? @relation("YaskravaAssignedApplications", fields: [assignedYaskravaUserId], references: [id], onDelete: SetNull)
  financingCase FinancingCase?
  auditLogs   AuditLog[]

  @@index([dealerId, createdAt])
  @@index([dealerId, status])
  @@index([dealerId, financingStatus])
  @@index([dealerId, archived, deletedAt])
  @@index([vehicleId])
  @@index([assignedDealerUserId])
  @@index([assignedYaskravaUserId])
}

model PartnerLead {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  contactedAt     DateTime?
  decisionAt      DateTime?
  archived        Boolean           @default(false)
  deletedAt       DateTime?

  sourceDomain    String
  sourcePath      String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?

  companyName     String
  contactName     String
  phone           String?
  email           String
  city            String?
  website         String?
  fleetSize       String?
  message         String?

  status          PartnerLeadStatus @default(NEW)
  adminNote       String?

  convertedDealerId String?
  convertedDealer Dealer?           @relation("ConvertedDealerPartnerLeads", fields: [convertedDealerId], references: [id], onDelete: SetNull)
  auditLogs       AuditLog[]

  @@index([status, createdAt])
  @@index([archived, deletedAt])
  @@index([convertedDealerId])
}

enum VehicleAvailability {
  IN_TRANSIT
  ON_SITE
  SOLD
}

model Vehicle {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  availability  VehicleAvailability @default(IN_TRANSIT)
  published     Boolean             @default(true)
  featured      Boolean             @default(false)
  leasingEligible Boolean           @default(true)

  slug          String
  stockNumber   String?
  title         String
  make          String?
  model         String?
  year          Int?
  mileageKm     Int?
  fuel          String?
  transmission  String?

  priceCzk      Int?
  description   String?
  imageUrl      String?
  videoUrl      String?
  videoGallery  Json?

  vinLast6      String?
  dealerId      String

  dealer        Dealer              @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  images        VehicleImage[]
  applications  Application[]
  auditLogs     AuditLog[]

  @@unique([dealerId, slug])
  @@index([dealerId, availability])
  @@index([dealerId, published, deletedAt])
}

model VehicleImage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  vehicleId  String
  url        String
  alt        String?
  sortOrder  Int      @default(0)

  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, sortOrder])
}

model Vacancy {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  title          String
  city           String?
  employmentType String?
  salary         String?
  description    String?
  contactEmail   String?
  sortOrder      Int      @default(0)
  published      Boolean  @default(true)

  dealerId       String
  dealer         Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([dealerId, published, deletedAt, sortOrder])
}

model FinancingCase {
  id                    String           @id @default(cuid())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  status                FinancingStatus  @default(NEW)
  lenderName            String?
  requestedAmountCzk    Int?
  approvedAmountCzk     Int?
  monthlyPaymentCzk     Int?
  decisionNote          String?

  applicationId         String           @unique
  assignedYaskravaUserId String?

  application           Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assignedYaskravaUser  AdminUser?       @relation("YaskravaAssignedFinancingCases", fields: [assignedYaskravaUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedYaskravaUserId, status])
}

model DealerDailyMetric {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  date                 DateTime
  vehicleCount         Int      @default(0)
  applicationsTotal    Int      @default(0)
  applicationsApproved Int      @default(0)
  applicationsRejected Int      @default(0)

  dealerId             String
  dealer               Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([dealerId, date])
  @@index([date])
}

model AuditLog {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())

  action     AuditAction
  actorType  AuditActorType @default(USER)
  message    String?
  targetId   String?
  metadata   Json?

  actorUserId String?
  dealerId    String?
  applicationId String?
  partnerLeadId String?
  vehicleId   String?

  actorUser   AdminUser?    @relation("UserAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  dealer      Dealer?       @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  application Application?  @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  partnerLead PartnerLead?  @relation(fields: [partnerLeadId], references: [id], onDelete: SetNull)
  vehicle     Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([dealerId, createdAt])
  @@index([applicationId, createdAt])
  @@index([partnerLeadId, createdAt])
  @@index([vehicleId, createdAt])
  @@index([actorUserId, createdAt])
}

